<Window x:Class="CwsEditor.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Stitch Helper"
        Icon="Assets/StitchHelper.ico"
        Height="1032"
        Width="1680"
        MinHeight="900"
        MinWidth="1400"
        Background="{StaticResource AppBackgroundBrush}"
        AllowDrop="True"
        DragEnter="Window_DragOver"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        Closed="Window_Closed">
    <Window.Resources>
        <Style x:Key="ToolbarCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="PanelValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Width" Value="42" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="DepthOverlayTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="4"
                                      Opacity="1"
                                      ShadowDepth="0" />
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ChromeBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="OpenButton"
                            Content="Open CWS"
                            Width="108"
                            Margin="0,0,8,0"
                            Click="OpenButton_Click" />
                    <Button x:Name="SaveButton"
                            Content="Save Edited CWS"
                            Width="132"
                            Margin="0,0,8,0"
                            Click="SaveButton_Click" />
                    <Button x:Name="ResetButton"
                            Content="Reset Edits"
                            Width="102"
                            Margin="0,0,8,0"
                            Click="ResetButton_Click" />
                    <Button x:Name="BrowseOutputButton"
                            Content="Choose Output"
                            Width="114"
                            Click="BrowseOutputButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,18,0" VerticalAlignment="Center">
                    <TextBlock x:Name="InputPathTextBlock"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13"
                               Text="No input file loaded." />
                    <TextBlock x:Name="OutputPathTextBlock"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               Text="Output path will appear here." />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource ToolbarCaptionStyle}" Text="Source Units" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                        <ToggleButton x:Name="SourceMetersToggleButton"
                                      Width="72"
                                      Margin="0,0,6,0"
                                      IsChecked="True"
                                      Content="Meters"
                                      Click="UnitToggleButton_Click" />
                        <ToggleButton x:Name="SourceFeetToggleButton"
                                      Width="56"
                                      Content="Feet"
                                      Click="UnitToggleButton_Click" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource ToolbarCaptionStyle}" Text="Display" />
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="DisplayMetricToggleButton"
                                      Width="68"
                                      Margin="0,0,6,0"
                                      IsChecked="True"
                                      Content="Metric"
                                      Click="UnitToggleButton_Click" />
                        <ToggleButton x:Name="DisplayImperialToggleButton"
                                      Width="74"
                                      Content="Imperial"
                                      Click="UnitToggleButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Global Geometry" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Vertical Scale" />
                        <TextBox x:Name="GlobalScaleTextBox"
                                 Grid.Row="1"
                                 Margin="0,4,8,0"
                                 Text="1.000" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,4,0,0"
                                Content="Apply"
                                Click="ApplyGlobalGeometryButton_Click" />
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Selected Geometry" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="132" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Region Scale" />
                        <Button Grid.Column="1"
                                Padding="8,4"
                                MinHeight="24"
                                Content="Crop Selection Out"
                                Click="CropSelectionButton_Click" />
                        <TextBox x:Name="SelectionScaleTextBox"
                                 Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Margin="0,4,0,0"
                                 Text="1.000" />
                        <Button Grid.Row="2"
                                Grid.Column="1"
                                Margin="0,6,0,0"
                                Content="Upsert"
                                Click="ApplySelectionGeometryButton_Click" />
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Global Tone" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Brightness" />
                        <Slider x:Name="GlobalBrightnessSlider"
                                Grid.Column="1"
                                Minimum="-100"
                                Maximum="100"
                                Value="0"
                                ValueChanged="ToneSlider_ValueChanged"
                                PreviewMouseLeftButtonUp="ToneSlider_PreviewMouseLeftButtonUp"
                                LostMouseCapture="ToneSlider_LostMouseCapture" />
                        <TextBlock x:Name="GlobalBrightnessValueTextBlock"
                                   Grid.Column="2"
                                   Style="{StaticResource PanelValueStyle}"
                                   Text="0" />

                        <TextBlock Grid.Row="1" Style="{StaticResource FieldLabelStyle}" Text="Contrast" />
                        <Slider x:Name="GlobalContrastSlider"
                                Grid.Row="1"
                                Grid.Column="1"
                                Minimum="-100"
                                Maximum="100"
                                Value="0"
                                ValueChanged="ToneSlider_ValueChanged"
                                PreviewMouseLeftButtonUp="ToneSlider_PreviewMouseLeftButtonUp"
                                LostMouseCapture="ToneSlider_LostMouseCapture" />
                        <TextBlock x:Name="GlobalContrastValueTextBlock"
                                   Grid.Row="1"
                                   Grid.Column="2"
                                   Style="{StaticResource PanelValueStyle}"
                                   Text="0" />

                        <TextBlock Grid.Row="2" Style="{StaticResource FieldLabelStyle}" Text="Sharpness" />
                        <Slider x:Name="GlobalSharpnessSlider"
                                Grid.Row="2"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="100"
                                Value="0"
                                ValueChanged="ToneSlider_ValueChanged"
                                PreviewMouseLeftButtonUp="ToneSlider_PreviewMouseLeftButtonUp"
                                LostMouseCapture="ToneSlider_LostMouseCapture" />
                        <TextBlock x:Name="GlobalSharpnessValueTextBlock"
                                   Grid.Row="2"
                                   Grid.Column="2"
                                   Style="{StaticResource PanelValueStyle}"
                                   Text="0" />

                        <CheckBox x:Name="GlobalNormalizeCheckBox"
                                  Grid.Row="3"
                                  Grid.ColumnSpan="3"
                                  Margin="0,2,0,0"
                                  Content="Normalize"
                                  Click="NormalizeToneCheckBox_Click" />
                        <Button Grid.Row="4"
                                Grid.ColumnSpan="3"
                                Margin="0,6,0,0"
                                Content="Apply Global Tone"
                                Click="ApplyGlobalToneButton_Click" />
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="3" Header="Selected Tone" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Brightness" />
                        <Slider x:Name="SelectionBrightnessSlider"
                                Grid.Column="1"
                                Minimum="-100"
                                Maximum="100"
                                Value="0"
                                ValueChanged="ToneSlider_ValueChanged"
                                PreviewMouseLeftButtonUp="ToneSlider_PreviewMouseLeftButtonUp"
                                LostMouseCapture="ToneSlider_LostMouseCapture" />
                        <TextBlock x:Name="SelectionBrightnessValueTextBlock"
                                   Grid.Column="2"
                                   Style="{StaticResource PanelValueStyle}"
                                   Text="0" />

                        <TextBlock Grid.Row="1" Style="{StaticResource FieldLabelStyle}" Text="Contrast" />
                        <Slider x:Name="SelectionContrastSlider"
                                Grid.Row="1"
                                Grid.Column="1"
                                Minimum="-100"
                                Maximum="100"
                                Value="0"
                                ValueChanged="ToneSlider_ValueChanged"
                                PreviewMouseLeftButtonUp="ToneSlider_PreviewMouseLeftButtonUp"
                                LostMouseCapture="ToneSlider_LostMouseCapture" />
                        <TextBlock x:Name="SelectionContrastValueTextBlock"
                                   Grid.Row="1"
                                   Grid.Column="2"
                                   Style="{StaticResource PanelValueStyle}"
                                   Text="0" />

                        <TextBlock Grid.Row="2" Style="{StaticResource FieldLabelStyle}" Text="Sharpness" />
                        <Slider x:Name="SelectionSharpnessSlider"
                                Grid.Row="2"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="100"
                                Value="0"
                                ValueChanged="ToneSlider_ValueChanged"
                                PreviewMouseLeftButtonUp="ToneSlider_PreviewMouseLeftButtonUp"
                                LostMouseCapture="ToneSlider_LostMouseCapture" />
                        <TextBlock x:Name="SelectionSharpnessValueTextBlock"
                                   Grid.Row="2"
                                   Grid.Column="2"
                                   Style="{StaticResource PanelValueStyle}"
                                   Text="0" />

                        <CheckBox x:Name="SelectionNormalizeCheckBox"
                                  Grid.Row="3"
                                  Grid.ColumnSpan="3"
                                  Margin="0,2,0,0"
                                  Content="Normalize"
                                  Click="NormalizeToneCheckBox_Click" />
                        <Button Grid.Row="4"
                                Grid.ColumnSpan="3"
                                Margin="0,6,0,0"
                                Content="Upsert Selected Tone"
                                Click="ApplySelectionToneButton_Click" />
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="4" Header="Regions">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ListView x:Name="RegionsListView"
                                  Margin="0,0,0,6"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectionChanged="RegionsListView_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="On" Width="42">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Padding="6,2"
                                                        MinHeight="22"
                                                        Tag="{Binding Id}"
                                                        Content="{Binding ToggleLabel}"
                                                        Click="ToggleRegionButton_Click" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Name" Width="72" DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Source Y" Width="88" DisplayMemberBinding="{Binding Interval}" />
                                    <GridViewColumn Header="Edits" Width="112" DisplayMemberBinding="{Binding Summary}" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Width="120"
                                    Margin="0,0,8,0"
                                    Content="Remove Selected"
                                    Click="RemoveSelectedRegionButton_Click" />
                            <Button Width="84"
                                    Content="Clear All"
                                    Click="ClearRegionsButton_Click" />
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,10"
                        Margin="0,0,0,8">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Zoom" />
                            <Slider x:Name="ZoomSlider"
                                    Minimum="0.15"
                                    Maximum="1.5"
                                    Width="210"
                                    Value="0.35"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="False"
                                    ValueChanged="ZoomSlider_ValueChanged" />
                            <TextBlock x:Name="ZoomValueTextBlock"
                                       Margin="10,0,18,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="35%" />
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Ctrl+wheel zooms. Shift+drag in the viewer to select." />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelAltBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="18" />
                        </Grid.RowDefinitions>

                        <ScrollViewer x:Name="ViewerScrollViewer"
                                      Grid.Row="0"
                                      Grid.Column="0"
                                      Background="{StaticResource PanelAltBackgroundBrush}"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      ScrollChanged="ViewerScrollViewer_ScrollChanged"
                                      PreviewMouseWheel="ViewerScrollViewer_PreviewMouseWheel">
                            <Canvas x:Name="ViewerCanvas"
                                    Background="{StaticResource PanelAltBackgroundBrush}"
                                    MouseMove="ViewerCanvas_MouseMove"
                                    MouseLeave="ViewerCanvas_MouseLeave"
                                    MouseLeftButtonDown="ViewerCanvas_MouseLeftButtonDown"
                                    MouseLeftButtonUp="ViewerCanvas_MouseLeftButtonUp">
                                <Image x:Name="ViewportImage" Stretch="Fill" SnapsToDevicePixels="True" />
                                <Rectangle x:Name="ViewerSelectionRect"
                                           Visibility="Collapsed"
                                           Stroke="{StaticResource AccentBrush}"
                                           StrokeThickness="2"
                                           Fill="{StaticResource SelectionFillBrush}" />
                            </Canvas>
                        </ScrollViewer>

                        <Grid Grid.Row="0"
                              Grid.Column="0"
                              Panel.ZIndex="1"
                              IsHitTestVisible="False">
                            <TextBlock x:Name="ViewerTopDepthTextBlock"
                                       Style="{StaticResource DepthOverlayTextStyle}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Margin="12,12,0,0"
                                       Text="" />
                            <TextBlock x:Name="ViewerBottomDepthTextBlock"
                                       Style="{StaticResource DepthOverlayTextStyle}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="12,0,0,12"
                                       Text="" />
                        </Grid>

                        <ScrollBar x:Name="ViewerVerticalScrollBar"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Style="{StaticResource ViewerScrollBarStyle}"
                                   Orientation="Vertical"
                                   Visibility="Collapsed"
                                   ValueChanged="ViewerVerticalScrollBar_ValueChanged" />

                        <ScrollBar x:Name="ViewerHorizontalScrollBar"
                                   Grid.Row="1"
                                   Grid.Column="0"
                                   Style="{StaticResource ViewerScrollBarStyle}"
                                   Orientation="Horizontal"
                                   Visibility="Collapsed"
                                   ValueChanged="ViewerHorizontalScrollBar_ValueChanged" />

                        <Border x:Name="ViewerScrollCorner"
                                Grid.Row="1"
                                Grid.Column="1"
                                Background="{StaticResource ScrollGutterBrush}"
                                BorderBrush="{StaticResource ScrollGutterBorderBrush}"
                                BorderThickness="1,1,0,0"
                                Visibility="Collapsed" />

                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="12"
                                Padding="10,6"
                                Background="#D914171B"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock x:Name="HoverInfoTextBlock"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13"
                                       Text="Depth / wrap angle / file orientation" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Overview" Margin="0,0,0,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="42" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Overview Zoom" />
                            <Slider x:Name="OverviewZoomSlider"
                                    Grid.Column="1"
                                    Minimum="0.4"
                                    Maximum="3"
                                    Value="1"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="False"
                                    ValueChanged="OverviewZoomSlider_ValueChanged" />
                            <TextBlock x:Name="OverviewZoomValueTextBlock"
                                       Grid.Column="2"
                                       Style="{StaticResource PanelValueStyle}"
                                       Text="100%" />
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{StaticResource PanelAltBackgroundBrush}"
                                CornerRadius="10"
                                Padding="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                </Grid.ColumnDefinitions>

                                <ScrollViewer x:Name="OverviewScrollViewer"
                                              Grid.Column="0"
                                              Background="{StaticResource PanelAltBackgroundBrush}"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              ScrollChanged="OverviewScrollViewer_ScrollChanged"
                                              PreviewMouseWheel="OverviewScrollViewer_PreviewMouseWheel">
                                    <Canvas x:Name="OverviewCanvas"
                                            Background="Transparent"
                                            ClipToBounds="True"
                                            MouseLeftButtonDown="OverviewSurface_MouseLeftButtonDown"
                                            MouseMove="OverviewSurface_MouseMove"
                                            MouseLeftButtonUp="OverviewSurface_MouseLeftButtonUp">
                                        <Image x:Name="OverviewImage"
                                               Stretch="Fill"
                                               SnapsToDevicePixels="True" />
                                        <Rectangle x:Name="OverviewSelectionRect"
                                                   Visibility="Collapsed"
                                                   Stroke="{StaticResource OverviewSelectionStrokeBrush}"
                                                   StrokeThickness="2"
                                                   Fill="{StaticResource OverviewSelectionFillBrush}" />
                                        <Rectangle x:Name="OverviewViewportRect"
                                                   Visibility="Collapsed"
                                                   Stroke="{StaticResource OverviewViewportBrush}"
                                                   StrokeThickness="2" />
                                    </Canvas>
                                </ScrollViewer>

                                <Grid Grid.Column="0"
                                      Panel.ZIndex="1"
                                      IsHitTestVisible="False">
                                    <TextBlock x:Name="OverviewTopDepthTextBlock"
                                               Style="{StaticResource DepthOverlayTextStyle}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"
                                               Margin="12,12,0,0"
                                               Text="" />
                                    <TextBlock x:Name="OverviewBottomDepthTextBlock"
                                               Style="{StaticResource DepthOverlayTextStyle}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Bottom"
                                               Margin="12,0,0,12"
                                               Text="" />
                                </Grid>

                                <ScrollBar x:Name="OverviewVerticalScrollBar"
                                           Grid.Column="1"
                                           Style="{StaticResource ViewerScrollBarStyle}"
                                           Orientation="Vertical"
                                           Visibility="Collapsed"
                                           ValueChanged="OverviewVerticalScrollBar_ValueChanged" />
                            </Grid>
                        </Border>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Selection">
                    <StackPanel>
                        <TextBlock x:Name="SelectionSummaryTextBlock"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Shift+drag in the overview or main viewer to select a depth interval. Drag the yellow box to move the current viewport." />
                        <Button Margin="0,8,0,0"
                                Content="Clear Selection"
                                Click="ClearSelectionButton_Click" />
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Open a .cws file to begin." />
            </StatusBarItem>
            <StatusBarItem>
                <ProgressBar x:Name="ExportProgressBar"
                             Width="220"
                             Height="14"
                             Minimum="0"
                             Maximum="100"
                             Visibility="Collapsed" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="ExportProgressTextBlock"
                           Visibility="Collapsed"
                           Foreground="{StaticResource TextMutedBrush}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
